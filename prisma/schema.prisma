// PostMaster - AI Writing Assistant (Single-User Mode)
// Schema for API keys, style profiles, and content generations
// Uses embedded SQLite for zero-config local deployment

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ============================================================================
// API Key Management
// ============================================================================

// AIProvider values: OPENAI, ANTHROPIC, XAI, MISTRAL, STABILITY
// Stored as strings for SQLite compatibility

model APIKey {
  id            String   @id @default(cuid())
  provider      String   @unique // AIProvider enum stored as string
  encryptedKey  String   // Encrypted API key
  isValid       Boolean  @default(false)
  validModels   String   @default("[]") // JSON array of model IDs
  lastValidated DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// LiteLLM Proxy Configuration - alternative to individual API keys
model LiteLLMConfig {
  id            String   @id @default(cuid())
  endpoint      String   // LiteLLM proxy URL (e.g., http://localhost:4000)
  encryptedKey  String?  // Optional API key for the proxy
  isEnabled     Boolean  @default(true)
  isValid       Boolean  @default(false)
  
  // Cached discovered models (JSON array of LiteLLMModel objects)
  cachedModels  String   @default("[]")
  
  lastValidated DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ============================================================================
// Style Profile & Content Samples
// ============================================================================

model StyleProfile {
  id          String   @id @default(cuid())
  
  // AI-extracted style characteristics
  tone        String?  // e.g., "conversational", "formal", "witty"
  voice       String?  // e.g., "first-person", "authoritative", "friendly"
  vocabulary  String?  // e.g., "technical", "simple", "creative"
  sentence    String?  // e.g., "short punchy", "long flowing", "varied"
  patterns    String?  // Common phrases, structures (JSON array of 8-10 patterns)
  
  // Enhanced style capture (Phase 1)
  uniqueVocabulary String?  // JSON array of distinctive words/phrases the user favors
  avoidPatterns    String?  // JSON array of phrases the user never uses
  writingQuirks    String?  // JSON: punctuation habits, emoji usage, caps preferences
  sampleExcerpts   String?  // JSON array of 3-5 representative paragraphs for few-shot
  openingStyles    String?  // JSON array of how user typically opens pieces
  closingStyles    String?  // JSON array of how user typically closes pieces
  
  // User-provided context
  bio         String?  // About the user
  context     String?  // Writing context (blogger, marketer, etc.)
  
  // Manual overrides
  overrides   String?  // JSON of manual style adjustments
  
  analyzedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ContentSample {
  id            String   @id @default(cuid())
  url           String   // Original URL
  title         String?  // Extracted title
  extractedText String?  // Extracted content (stored as text)
  wordCount     Int?
  analyzedAt    DateTime?
  createdAt     DateTime @default(now())
}

// ============================================================================
// Content Generation
// ============================================================================

// GenerationStatus values: PENDING, GENERATING, SYNTHESIZING, COMPLETED, FAILED
// ContentType values: BLOG_POST, TWEET_THREAD, LINKEDIN_POST, EMAIL, ARTICLE, OTHER

model Generation {
  id           String   @id @default(cuid())
  
  // Input
  prompt       String
  contentType  String   @default("BLOG_POST")
  lengthPref   String?  // short, medium, long
  styleContext String?  // JSON snapshot of style profile at generation time
  contentMode  String   @default("new")  // "new" or "enhance"
  sourceContent String? // Original content when enhancing existing content
  
  // Citation source mapping for URL references
  sourceMap    String?  // JSON: Array<{ url: string; title: string }>
  
  // Generation preferences
  enableCitations Boolean  @default(false)
  enableEmojis    Boolean  @default(false)
  
  // State
  status       String   @default("PENDING")
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  outputs            GenerationOutput[]
  synthesizedContent SynthesizedContent?
  critiques          GenerationCritique[]

  @@index([createdAt])
}

model GenerationOutput {
  id           String   @id @default(cuid())
  generationId String
  
  provider     String   // AIProvider stored as string
  model        String   // Specific model used (e.g., "gpt-4o", "claude-3-opus")
  content      String   // Generated content
  tokensUsed   Int?
  latencyMs    Int?     // Time taken in milliseconds
  
  createdAt    DateTime @default(now())

  generation Generation @relation(fields: [generationId], references: [id], onDelete: Cascade)

  @@index([generationId])
}

model SynthesizedContent {
  id           String   @id @default(cuid())
  generationId String   @unique
  
  // Final content
  content      String
  
  // LLM's reasoning for synthesis decisions (transparency)
  reasoning    String?  // JSON: { summary, decisions: [{ aspect, choice, rationale }] }
  
  // Synthesis strategy used
  strategy     String   @default("basic") // basic, sequential, debate
  
  // Iteration tracking
  version      Int      @default(1)
  feedback     String?  // JSON array of feedback items
  
  // Image generation
  imageUrl     String?
  imagePrompt  String?
  
  // Parent-child versioning: tracks lineage across regenerations
  parentSynthesisId String?
  globalVersion     Int      @default(1) // Version number in the full lineage chain
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  generation    Generation @relation(fields: [generationId], references: [id], onDelete: Cascade)
  versions      SynthesisVersion[]
  contributions SynthesisContribution[]
  parentSynthesis SynthesizedContent?  @relation("SynthesisLineage", fields: [parentSynthesisId], references: [id], onDelete: SetNull)
  childSyntheses  SynthesizedContent[] @relation("SynthesisLineage")
}

// ============================================================================
// Multi-Model Critique System
// ============================================================================

// Stores critiques from one model evaluating other drafts
model GenerationCritique {
  id           String   @id @default(cuid())
  generationId String
  
  // Critic model info
  fromProvider String   // Provider of the critiquing model
  fromModel    String   // Model that provided the critique
  
  // Critique data (JSON containing CritiqueOutput structure)
  critiques    String   // JSON: { targetDrafts, overallRating, consensusPoints }
  
  // Round tracking for debate mode
  debateRound  Int      @default(0) // 0 for sequential mode, 1+ for debate rounds
  
  createdAt    DateTime @default(now())

  generation Generation @relation(fields: [generationId], references: [id], onDelete: Cascade)

  @@index([generationId])
  @@index([generationId, debateRound])
}

// ============================================================================
// User Preferences
// ============================================================================

model UserPreferences {
  id                   String   @id @default(cuid())
  
  // Synthesis settings
  synthesisStrategy    String   @default("basic") // basic, sequential, debate
  debateMaxRounds      Int      @default(3)       // Max debate rounds
  showCritiqueDetails  Boolean  @default(true)    // Show critique details in UI
  
  // Primary model preference (used for synthesis, iteration, etc.)
  primaryModelProvider String?  // e.g., "LITELLM", "OPENAI", "ANTHROPIC"
  primaryModelId       String?  // e.g., "azure-gpt-4o", "gpt-4o", "claude-3-opus"
  
  // Future: other user preferences can be added here
  
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

// ============================================================================
// Model Performance Analytics
// ============================================================================

model ModelAnalytics {
  id           String   @id @default(cuid())
  provider     String   // AIProvider
  modelId      String   // Specific model identifier
  
  // Aggregate stats
  totalRuns    Int      @default(0)
  totalTokens  Int      @default(0)
  totalLatencyMs Int    @default(0)
  avgRating    Float?   // Average quality rating from critiques
  
  // Last usage tracking
  lastUsed     DateTime?
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([provider, modelId])
}

// ============================================================================
// Model Quality Tracking
// ============================================================================

// Tracks which model's content was selected in each synthesis decision
model SynthesisContribution {
  id           String   @id @default(cuid())
  synthesisId  String
  generationId String   // For easier querying
  
  // Model that contributed
  provider     String   // AIProvider
  model        String   // Specific model identifier
  
  // Contribution details
  aspectCount  Int      @default(0)  // Number of decisions where this model was selected
  totalAspects Int      @default(0)  // Total decisions in this synthesis
  aspectTypes  String   @default("[]") // JSON array of aspect names (e.g., ["structure", "opening"])
  
  // Starred sections tracking
  starredCount Int      @default(0)  // Number of starred sections from this model
  
  createdAt    DateTime @default(now())
  
  synthesis    SynthesizedContent @relation(fields: [synthesisId], references: [id], onDelete: Cascade)
  
  @@index([synthesisId])
  @@index([provider, model])
  @@index([generationId])
}

// ============================================================================
// Content Version History (for Diff View)
// ============================================================================

model SynthesisVersion {
  id                   String   @id @default(cuid())
  synthesizedContentId String
  version              Int
  content              String   // Content snapshot at this version
  reasoning            String?  // LLM reasoning snapshot at this version
  feedback             String?  // Feedback that was applied to create next version
  
  createdAt            DateTime @default(now())

  synthesizedContent   SynthesizedContent @relation(fields: [synthesizedContentId], references: [id], onDelete: Cascade)

  @@index([synthesizedContentId])
  @@unique([synthesizedContentId, version])
}

// ============================================================================
// Draft Auto-Save
// ============================================================================

// Stores in-progress work to prevent loss on refresh/close
model Draft {
  id        String   @id @default(cuid())
  
  // Editor state snapshot
  prompt        String
  contentType   String   @default("BLOG_POST")
  lengthPref    String?
  contentMode   String   @default("new")
  existingContent String?
  
  // Model selection
  selectedModels String   // JSON: Array<{ provider, modelId }>
  yoloMode      Boolean  @default(false)
  
  // References and knowledge
  references         String   @default("[]") // JSON: ReferenceSource[]
  selectedKnowledge  String   @default("[]") // JSON: string[] (knowledge IDs)
  enableCitations    Boolean  @default(false)
  
  // Synthesis settings
  synthesisStrategy String   @default("basic")
  
  // Timestamps
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  
  @@index([updatedAt])
}

// ============================================================================
// Knowledge Base
// ============================================================================

// KnowledgeEntry type values: "url", "text", "file"
// mimeType values (for files): "application/pdf", "text/plain"

model KnowledgeEntry {
  id           String   @id @default(cuid())
  title        String   // User-defined or auto-generated title
  type         String   // "url" | "text" | "file"
  source       String   // URL, filename, or "pasted"
  mimeType     String?  // For files: "application/pdf", "text/plain"
  content      String   // Extracted or pasted text content
  wordCount    Int
  isActive     Boolean  @default(true)
  subpageLinks Json?    // For URLs: discovered subpage links [{ url, title }]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}
