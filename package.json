{
  "name": "postmaster",
  "version": "1.2.3",
  "private": true,
  "description": "AI-Powered Multi-Model Writing Assistant",
  "author": "Himanshu Gupta",
  "license": "MIT",
  "main": "electron/dist/main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/himoacs/postmaster.git"
  },
  "scripts": {
    "dev": "next dev -p 3456",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest",
    "test:unit": "vitest run --reporter=verbose",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "pre-release": "node scripts/pre-release-checks.js",
    "postinstall": "npx prisma generate",
    "rebuild:native": "npm rebuild better-sqlite3",
    "rebuild:electron": "npx electron-rebuild -f -w better-sqlite3",
    "electron:deps": "node scripts/prepare-electron-deps.js",
    "electron:dev": "concurrently \"pnpm dev\" \"wait-on http://localhost:3456 && pnpm electron:start\"",
    "electron:start": "NODE_ENV=development electron .",
    "electron:prepare": "rm -rf .next/standalone_flat && rsync -aL --ignore-errors .next/standalone/ .next/standalone_flat/ && node scripts/fix-standalone.js",
    "electron:rebuild-standalone": "node scripts/rebuild-standalone-native.js",
    "electron:build": "pnpm build && pnpm electron:prepare && pnpm electron:rebuild-standalone && pnpm electron:deps && pnpm electron:compile && electron-builder",
    "electron:build:mac": "pnpm build && pnpm electron:prepare && pnpm electron:rebuild-standalone && pnpm electron:deps && pnpm electron:compile && electron-builder --mac",
    "electron:build:win": "pnpm build && pnpm electron:prepare && pnpm electron:rebuild-standalone && pnpm electron:deps && pnpm electron:compile && electron-builder --win",
    "electron:build:linux": "pnpm build && pnpm electron:prepare && pnpm electron:rebuild-standalone && pnpm electron:deps && pnpm electron:compile && electron-builder --linux",
    "electron:compile": "tsc -p electron/tsconfig.json"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.0",
    "@hookform/resolvers": "^5.2.2",
    "@mistralai/mistralai": "^2.2.1",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tailwindcss/typography": "^0.5.19",
    "better-sqlite3": "^12.9.0",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.3",
    "lucide-react": "^1.9.0",
    "mammoth": "^1.12.0",
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "officeparser": "^6.1.0",
    "openai": "^6.34.0",
    "pdf-parse": "^1.1.1",
    "prisma": "^7.8.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.73.1",
    "react-markdown": "^10.1.0",
    "shadcn": "^4.4.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@playwright/test": "^1.59.1",
    "@swc/helpers": "^0.5.21",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "concurrently": "^9.1.0",
    "electron": "^36.3.2",
    "electron-builder": "^26.0.12",
    "electron-squirrel-startup": "^1.0.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "happy-dom": "^20.9.0",
    "msw": "^2.13.6",
    "playwright": "^1.59.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.5",
    "wait-on": "^8.0.3"
  }
}
